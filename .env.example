# Copy this file to `.env` and fill in your own values:  cp .env.example .env
# NEVER commit the real .env — it holds secrets. Only this .example is committed.

# --- Qwen (Alibaba Cloud DashScope, OpenAI-compatible) ---
DASHSCOPE_API_KEY=sk-your-dashscope-key-here
# International endpoint (default). For mainland China, use:
#   https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# qwen-plus (balanced) | qwen-max (best reasoning) | qwen-turbo/qwen-flash (cheapest)
QWEN_MODEL=qwen-flash

# --- Data ---
# Path to the deduped PSX enforcement DB. Defaults to ./data/psx.db if unset.
DB_PATH=data/psx.db
# Directory of markdown financial summaries the finance agent reads.
FINANCE_DATA_DIR=./data_md

# --- Postgres: per-session checkpointer AND cross-session memory store ---
# When running via docker-compose, you do NOT need to set DB_URL here — compose sets
# it to the `db` service automatically. These POSTGRES_* vars configure that container
# AND are used to build the DB_URL (see docker-compose.yml). Set your real credentials:
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=psxmemory

# Only needed when running the app WITHOUT compose (bare `uvicorn main:app` against an
# external Postgres). Compose ignores these two.
# DB_URL_LOCAL=postgresql://postgres:postgres@localhost:5433/psxmemory
# DB_URL=postgresql://user:pass@host:5432/dbname

# --- Auth (Phase 2): signing key for JWT login tokens ---
# Generate a strong random value, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string

# --- LangSmith tracing (optional; EU-region key in this project) ---
# LANGSMITH_API_KEY=ls-...
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_PROJECT=devpost-hackathon
