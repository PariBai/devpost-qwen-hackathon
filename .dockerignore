# --- VCS / IDE ---
.git
.gitignore
.vscode
.idea

# --- Secrets (injected at runtime via compose env_file, never baked into image) ---
.env
.env.local
.env.*.local

# --- Python cruft ---
__pycache__
**/__pycache__
*.py[cod]
*.egg-info
.pytest_cache
.ipynb_checkpoints

# --- Notebooks (dev only, not needed at runtime) ---
*.ipynb

# --- Frontend build artifacts (added later) ---
node_modules
frontend/node_modules
dist
build
.next

# --- Misc ---
*.log
.DS_Store
Thumbs.db
PROJECT_PLAN.md
